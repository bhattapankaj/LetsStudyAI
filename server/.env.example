# PostgreSQL connection (required)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/letsstudyai

# JWT signing secret — use a long random string in production (min 16 characters)
JWT_SECRET=your_jwt_secret_change_me_min_16_chars

# Optional: access token lifetime (default 7d)
# JWT_EXPIRES_IN=7d

# Provider API keys (multi-provider setup)
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
#
# Configure provider + model per agent (free-tier friendly example)
AI_PROVIDER_TUTOR=groq
AI_MODEL_TUTOR=llama-3.1-8b-instant
AI_PROVIDER_PLANNER=gemini
AI_MODEL_PLANNER=gemini-1.5-flash
AI_PROVIDER_EVALUATOR=openrouter
AI_MODEL_EVALUATOR=meta-llama/llama-3.1-8b-instruct:free
#
# Legacy Groq model keys (still supported when provider is groq):
# GROQ_MODEL=llama-3.1-8b-instant
# GROQ_MODEL_TUTOR=llama-3.1-8b-instant
# GROQ_MODEL_EVALUATOR=gemma2-9b-it
# GROQ_MODEL_PLANNER=mixtral-8x7b-32768
# GROQ_MODEL_QUIZ=llama-3.3-70b-versatile
# GROQ_MODEL_PLANNER_GENERATE=llama-3.3-70b-versatile
# GROQ_MODEL_PLANNER_INSIGHTS=llama-3.1-8b-instant

PORT=3001
